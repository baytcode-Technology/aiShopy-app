{
  "expo": {
    "name": "AISHOPY",
    "slug": "aishopy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/aishopy_logo.png",
    "scheme": "aishopyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/aishopy_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aishopy.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/aishopy_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/aishopy_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AISHOPY to access your photos for product images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "005f6373-309d-4dfa-bf83-aac91cb2205b"
      }
    },
    "owner": "muhammed_nuaim"
  }
}
