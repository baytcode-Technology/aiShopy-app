{
  "expo": {
    "name": "AiShopy",
    "slug": "aishopy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_logo.jpg",
    "scheme": "aishopyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app_logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aishopy.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "upi",
          "tez",
          "phonepe",
          "paytmmp",
          "gpay",
          "credpay",
          "bhim",
          "upi",
          "tez",
          "phonepe",
          "paytmmp",
          "gpay",
          "credpay",
          "bhim"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "label": "AiShopy",
      "package": "com.aishopy.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app_logo.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "manifest": {
        "queries": [
          {
            "intent": {
              "action": "VIEW",
              "data": [
                {
                  "scheme": "upi"
                }
              ]
            }
          },
          {
            "intent": {
              "action": "VIEW",
              "data": [
                {
                  "scheme": "tez"
                }
              ]
            }
          },
          {
            "intent": {
              "action": "VIEW",
              "data": [
                {
                  "scheme": "phonepe"
                }
              ]
            }
          },
          {
            "intent": {
              "action": "VIEW",
              "data": [
                {
                  "scheme": "paytmmp"
                }
              ]
            }
          }
        ]
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app_logo.jpg"
    },
    "plugins": [
      "./plugins/with-android-app-name.js",
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AiShopy to access your photos for product images."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.573339565981-vdanmkkiua7b27vatukthqiomh3qvs3h"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app_logo.jpg",
          "color": "#0a0a0b"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "005f6373-309d-4dfa-bf83-aac91cb2205b"
      }
    },
    "owner": "muhammed_nuaim"
  }
}
